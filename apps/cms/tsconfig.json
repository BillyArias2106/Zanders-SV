{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@starter/page-sections": ["../../packages/page-sections/src/index.ts"],
      "@starter/page-sections/*": ["../../packages/page-sections/src/*"],
      "@payload-config": ["./payload.config.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    ".next/types/**/*.ts",
    "../../packages/page-sections/src/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
