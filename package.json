{
  "name": "starter-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monorepo para un sitio nuevo.",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @starter/web dev",
    "dev:cms": "pnpm --filter @starter/cms dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "cms:types": "pnpm --filter @starter/cms generate:types",
    "cms:importmap": "pnpm --filter @starter/cms generate:importmap"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
