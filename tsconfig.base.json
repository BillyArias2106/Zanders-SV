{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@starter/page-sections": ["packages/page-sections/src/index.ts"],
      "@starter/page-sections/*": ["packages/page-sections/src/*"],
      "@starter/ui": ["packages/ui/src/index.ts"],
      "@starter/ui/*": ["packages/ui/src/*"]
    }
  }
}
